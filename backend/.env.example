# Скопируйте в .env и подставьте свои значения.
# Docker Compose уже подключает ./backend/.env к контейнеру backend.
#
# Миграции Prisma нужно запускать из каталога backend (или: npm run db:migrate из frontend):
#   cd backend && npx prisma migrate deploy
#   npm run db:migrate

# PostgreSQL для Prisma
# Рекомендуемый SSL-режим для будущей совместимости pg: sslmode=verify-full
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public&sslmode=verify-full"

# JWT_SECRET для подписи access-токенов (короткая жизнь)
JWT_SECRET=""

# Срок access JWT (например 15m, 1h). Refresh — HttpOnly-кука + таблица RefreshSession.
JWT_ACCESS_EXPIRES_IN="7d"

# Срок refresh-сессии в днях (кука + запись в БД)
JWT_REFRESH_DAYS="90"

# В dev на http://localhost задайте false, иначе браузер не примет Secure-куку.
# В production обычно не задают (по умолчанию secure=true при NODE_ENV=production).
# COOKIE_SECURE="false"

# Для refresh-cookies с фронта нужен credentials: true в CORS.
# Нельзя использовать CORS_ORIGIN=* вместе с куками — укажите origin фронта Next (несколько через запятую).
# Если фронт ходит на API напрямую (NEXT_PUBLIC_API_URL=https://этот-же-api-хост... или другой API-домен):
#   локально:  CORS_ORIGIN="http://localhost:3000"
#   прод:      CORS_ORIGIN="https://ваш-сайт.ru"
# Альтернатива одному origin в production: FRONTEND_URL="https://ваш-сайт.ru"

# Web Push для Push API (сообщения из сервера)
WEB_PUSH_PUBLIC_KEY=""
WEB_PUSH_PRIVATE_KEY=""
WEB_PUSH_SUBJECT=""


# Cloudinary (голос /messages/voice, фото в чат /messages/image, аватар /users/me/avatar)
# https://console.cloudinary.com → Account / API Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Agora Voice Calling (token generation on backend)
# App ID и App Certificate берутся в Agora Console → Project → Security
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=