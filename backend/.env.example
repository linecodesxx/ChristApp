# Скопируйте в .env и подставьте свои значения.
# Docker Compose уже подключает ./backend/.env к контейнеру backend.
#
# Миграции Prisma нужно запускать из каталога backend (или: npm run db:migrate из frontend):
#   cd backend && npx prisma migrate deploy
#   npm run db:migrate

# PostgreSQL для Prisma
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# JWT_SECRET для подписи токенов
JWT_SECRET=""

# Web Push для Push API (сообщения из сервера)
WEB_PUSH_PUBLIC_KEY=""
WEB_PUSH_PRIVATE_KEY=""
WEB_PUSH_SUBJECT=""


# Cloudinary — загрузка голосовых (POST /messages/voice).
# Консоль: https://console.cloudinary.com → Account / API Keys (Cloud name, API Key, API Secret)
# Если не заданы — эндпоинт голоса вернёт 503.
# Поддерживаются и короткие имена: CLD_CLOUD_NAME, CLD_API_KEY, CLD_API_SECRET (см. cloudinary.service.ts).
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""