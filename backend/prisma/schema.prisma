generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  /// * Уникальный @username (латиница, нижний регистр).
  username          String             @unique
  password          String
  createdAt         DateTime           @default(now())
  isActive          Boolean            @default(true)
  avatarUrl         String?
  /// * Отображаемый ник (изначально совпадает с username).
  nickname          String?
  /// * Кастомный цвет текста (#RRGGBB), опционально.
  themeForegroundHex String? @db.VarChar(7)
  /// * Кастомный фон (#RRGGBB), опционально.
  themeBackgroundHex String? @db.VarChar(7)
  /// * Ключ шрифта: `inter` | `pastah` | `achiko`.
  themeFontKey      String? @db.VarChar(16)
  messages          Message[]
  pushSubscriptions PushSubscription[]
  memberships       RoomMember[]
  roomReadStates    RoomReadState[]
  savedVerses       SavedVerse[]
  reactions         Reaction[]
  refreshSessions   RefreshSession[]
}

/// * Opaque refresh token (хеш в БД, сырое значение только в HttpOnly-куке).
model RefreshSession {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum MessageType {
  TEXT
  VOICE
  IMAGE
  FILE
}

model Message {
  id        String      @id @default(uuid())
  type      MessageType @default(TEXT)
  content   String?
  fileUrl   String?
  senderId  String
  createdAt DateTime    @default(now())
  roomId    String      @default(dbgenerated("'00000000-0000-0000-0000-000000000001'::uuid")) @db.Uuid
  room      Room        @relation(fields: [roomId], references: [id])
  sender    User        @relation(fields: [senderId], references: [id], onDelete: Cascade)
  reactions Reaction[]

  @@index([roomId, createdAt])
}

model Reaction {
  id        String   @id @default(uuid())
  userId    String
  messageId String
  type      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([userId, messageId, type])
  @@index([messageId, createdAt])
}

model Room {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title      String          @unique
  createdAt  DateTime        @default(now())
  messages   Message[]
  members    RoomMember[]
  readStates RoomReadState[]
}

model RoomMember {
  roomId   String   @db.Uuid
  userId   String
  joinedAt DateTime @default(now())
  room     Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([roomId, userId])
  @@index([userId])
}

model SavedVerse {
  id          String   @id @default(uuid())
  userId      String
  book        String
  chapter     Int
  verse       Int
  text        String
  translation String
  savedAt     DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, book, chapter, verse, translation])
  @@index([userId, savedAt])
}

model RoomReadState {
  roomId     String   @db.Uuid
  userId     String
  lastReadAt DateTime @default(dbgenerated("to_timestamp((0)::double precision)"))
  updatedAt  DateTime @updatedAt
  room       Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([roomId, userId])
  @@index([userId, lastReadAt])
}

model PushSubscription {
  id             String    @id @default(cuid())
  userId         String
  endpoint       String    @unique
  p256dh         String
  auth           String
  expirationTime String?
  userAgent      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lastUsedAt     DateTime?
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([updatedAt])
}
